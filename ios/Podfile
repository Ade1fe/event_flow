# Uncomment this line to define a global platform for your project
platform :ios, '12.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
# Force CocoaPods to use the legacy build system
ENV['COCOAPODS_DISABLE_DETERMINISTIC_UUIDS'] = 'true'
install! 'cocoapods', :deterministic_uuids => false

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

# COMBINED post_install block
post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    
    # Fix for Firebase build issue with -G flag
    target.build_configurations.each do |config|
      # Set minimum iOS version
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '12.0'
      
      # Remove the problematic -G flag
      if config.build_settings['OTHER_CFLAGS']
        other_cflags = config.build_settings['OTHER_CFLAGS']
        if other_cflags.is_a?(Array)
          other_cflags.delete('-G')
          config.build_settings['OTHER_CFLAGS'] = other_cflags
        elsif other_cflags.is_a?(String)
          config.build_settings['OTHER_CFLAGS'] = other_cflags.gsub('-G', '')
        end
      end
      
      # Also check C++ flags
      if config.build_settings['OTHER_CPLUSPLUSFLAGS']
        other_cppflags = config.build_settings['OTHER_CPLUSPLUSFLAGS']
        if other_cppflags.is_a?(Array)
          other_cppflags.delete('-G')
          config.build_settings['OTHER_CPLUSPLUSFLAGS'] = other_cppflags
        elsif other_cppflags.is_a?(String)
          config.build_settings['OTHER_CPLUSPLUSFLAGS'] = other_cppflags.gsub('-G', '')
        end
      end
    end
  end
end